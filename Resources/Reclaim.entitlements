<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Reclaim ships as a non-sandboxed Developer ID app. It needs broad
    read access to scan the user's Library and caches; that comes from
    the user granting Full Disk Access in System Settings, not from an
    entitlement. Hardened Runtime is required for notarization, so we
    keep the entitlement set minimal.
  -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <false/>
</dict>
</plist>
